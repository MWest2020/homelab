# .env.example — shell environment for the operator.
# Copy to .env (gitignored), fill in the secrets, source before running
# terraform or ansible commands:
#
#   cp .env.example .env
#   $EDITOR .env
#   set -a; source .env; set +a
#
# This file documents the SHAPE only; .env itself is gitignored.

# --- Proxmox API token (scope: claude-lxc-iac only) ---
# Per-usecase tokens, scope-by-name. See ADR-011 in docs/decisions.md.
# Create in Proxmox UI: Datacenter -> Permissions -> API Tokens.
#   User: terraform@pve
#   Token ID: automation-lxc
#   Privilege Separation: off (token inherits user's TerraformProv role)
#
# This file is the source of PROXMOX_VE_API_TOKEN for THIS repo only.
# The homelab/ repo has its own .env with its own token; the two don't
# need to bridge.
export PROXMOX_VE_API_TOKEN='terraform@pve!automation-lxc=<paste-uuid-secret-here>'

# (Optional) the bpg/proxmox provider also reads PROXMOX_VE_ENDPOINT. Set
# only if you need to override what's pinned in terraform/versions.tf:
# export PROXMOX_VE_ENDPOINT=https://192.168.178.10:8006

# --- Ansible vault password file ---
# Points at a file (mode 0600, gitignored) containing the vault password.
# Generate the password once: openssl rand -base64 32 > ~/.vault_pass && chmod 600 ~/.vault_pass
export ANSIBLE_VAULT_PASSWORD_FILE="$HOME/.vault_pass"

# --- SSH key path (default usually fine) ---
# terraform/variables.tf default is ~/.ssh/id_ed25519_homelab.pub (the same
# key used for the rest of the homelab). We deliberately do NOT layer a
# dedicated key — see ADR-010. Only override below if you explicitly chose
# a per-host key model:
# export TF_VAR_ssh_public_key_path="$HOME/.ssh/id_ed25519_some_other.pub"
