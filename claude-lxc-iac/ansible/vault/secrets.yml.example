# ansible/vault/secrets.yml.example
# Cleartext shape — the real file (secrets.yml) is encrypted with ansible-vault
# and gitignored. To create it:
#
#   cp secrets.yml.example secrets.yml
#   <fill in real values>
#   ansible-vault encrypt secrets.yml
#
# Vault password lives in ~/.vault_pass on jumpy (mode 0600, gitignored everywhere).
# Reference via: export ANSIBLE_VAULT_PASSWORD_FILE=~/.vault_pass

---
# Single-use, pre-approved, non-ephemeral Tailscale auth key with tag:homelab-router.
# Mint via Tailscale admin → Settings → Keys → Generate auth key.
tailscale_authkey: "tskey-auth-<replace-with-real-key>"
