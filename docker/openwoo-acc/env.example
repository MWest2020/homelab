# Copy to .env (gitignored) en vul in op de VM /opt/openwoo-acc/.env.
# Ansible deploy't deze als template; sterke wachtwoorden via vault of
# ansible-managed random.

# --- Postgres ---
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=<sterke-random-password>

# --- Nextcloud admin (1e installatie) ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=<sterke-random-password>

# --- Woo-website (per-tenant branding) ---
# UPSTREAM_HOST en UPSTREAM_BASE staan al hardcoded in compose (wijzen naar
# onze Nextcloud-OpenCatalogi-API). Per-tenant branding via Gatsby env-vars:
WOO_ORGANISATION_NAME="OpenWoo Acceptatie"
WOO_THEME_CLASSNAME="utrecht-theme"
# WOO_JUMBOTRON_URL="https://example.org/jumbotron.jpg"
# WOO_FAVICON_URL="data:image/png;base64,..."
