# Kopieer naar .env en vul de waarden in vóór `docker compose up -d`.

# === Verplicht ===
# Hostname van jullie Nextcloud (zonder protocol, zonder pad)
NEXTCLOUD_HOST=nextcloud.gemeenteXYZ.nl

# Volledige URL naar de OpenCatalogi-API op jullie Nextcloud
NEXTCLOUD_API_URL=https://nextcloud.gemeenteXYZ.nl/apps/opencatalogi/api

# === Branding ===
# Naam van jullie organisatie, zoals het in de header / titel verschijnt
WOO_ORGANISATION_NAME=Gemeente XYZ

# NL Design System theme — bv. utrecht-theme, denhaag-theme, rotterdam-theme,
# of jullie eigen theme als die in de image zit. Default: utrecht-theme.
WOO_THEME_CLASSNAME=utrecht-theme

# === Optioneel ===
# Host-port op jullie Docker-host. Default 8081 als er niks ingevuld is.
# WOO_HOST_PORT=8081

# URL naar het jumbotron-plaatje (boven aan de pagina)
# WOO_JUMBOTRON_URL=https://cdn.gemeenteXYZ.nl/woo/jumbotron.jpg

# Favicon — kan een URL zijn of een data:image/png;base64,... blob
# WOO_FAVICON_URL=https://cdn.gemeenteXYZ.nl/favicon.png
