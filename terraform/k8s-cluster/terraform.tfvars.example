# Kopieer naar terraform.tfvars en pas aan. Token via TF_VAR_proxmox_api_token
# (terraform/k8s-cluster/.env op jumpy, cluster-token), niet hier.
#
# Templates staan per host (build-k8s-templates.yml): VMID's cluster-breed uniek, dus
# per host een eigen reeks -> px-01 CP=9001/worker=9002, px-02 9011/9012, px-03 9021/9022.

# Endpoint = px-01 via Tailscale (vanaf jumpy; LAN .11 is daar niet routeerbaar).
proxmox_endpoint = "https://100.120.76.22:8006"

# 6 VM's: 1 control-plane + 1 worker per host (anti-affinity over px-01/02/03).
# Control-plane VIP .201 (kube-vip) zit hier NIET in — die beheert Ansible/kube-vip.
vms = {
  cp-01   = { vm_id = 110, node_name = "px-01", ip = "192.168.178.202", template_vm_id = 9001, role = "control-plane" }
  cp-02   = { vm_id = 111, node_name = "px-02", ip = "192.168.178.203", template_vm_id = 9011, role = "control-plane" }
  cp-03   = { vm_id = 112, node_name = "px-03", ip = "192.168.178.204", template_vm_id = 9021, role = "control-plane" }
  node-01 = { vm_id = 113, node_name = "px-01", ip = "192.168.178.205", template_vm_id = 9002, role = "worker" }
  node-02 = { vm_id = 114, node_name = "px-02", ip = "192.168.178.206", template_vm_id = 9012, role = "worker" }
  node-03 = { vm_id = 115, node_name = "px-03", ip = "192.168.178.207", template_vm_id = 9022, role = "worker" }
}
